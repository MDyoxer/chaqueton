# ─────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# El archivo .env NUNCA debe subirse al repositorio.
# ─────────────────────────────────────────────────────────────

# Project ID del agente Dialogflow en Google Cloud
DIALOGFLOW_PROJECT_ID=tu-project-id

# Nombre del archivo JSON de credenciales de Dialogflow (relativo a la raíz)
DIALOGFLOW_CREDENTIALS=credenciales.json

# ID del calendario escolar de Google Calendar
# Se obtiene en: Google Calendar > Configuración > ID del calendario
CALENDAR_ID=tu-calendario@group.calendar.google.com
